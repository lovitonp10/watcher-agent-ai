# ============================================
# Tech Watch Agent - Environment Configuration
# ============================================
# This file contains ONLY secrets and credentials.
# Business logic configuration is in configs/*.yaml files.

# === LLM Provider Credentials ===
# API key for your LLM provider (OpenAI, Mistral, Anthropic, Groq, etc.)
# For Ollama (local), use: LLM_API_KEY=ollama
LLM_API_KEY=ollama

# Base URL for LLM API (optional, for custom endpoints)
# Ollama (local): http://localhost:11434
# OpenAI: https://api.openai.com/v1 (default)
# Custom endpoints: specify full URL
LLM_BASE_URL=http://localhost:11434

# === Email Configuration (for digest emails) ===
# Enable or disable email sending
EMAIL_ENABLED=false

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
EMAIL_USE_TLS=true

# Email Addresses
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=recipient@example.com

# === Notes ===
# - For Gmail, use App Password (not regular password): https://support.google.com/accounts/answer/185833
# - Business logic settings (models, chunk sizes, etc.) are in configs/*.yaml
# - See configs/llm.yaml for LLM provider and model selection
# - See configs/ingestion.yaml for data fetching parameters
# - See configs/rag.yaml for vector database settings
# - See configs/digest.yaml for email digest options
